// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum UserRole {
  OWNER
  MANAGER
}

model Apartment {
  id             String           @id @default(cuid())
  title          String
  slug           String           @unique
  shortDescription String         @default("")
  description    String
  maxGuests      Int
  bedrooms       Int              @default(1)
  bathrooms      Int              @default(1)
  basePriceCents Int
  currency       String           @default("EUR")
  isActive       Boolean          @default(true)
  sortOrder      Int              @default(0)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  photos         ApartmentPhoto[]
  rates          Rate[]
  bookings       Booking[]
  blockedDates   BlockedDate[]
}

model ApartmentPhoto {
  id          String    @id @default(cuid())
  apartmentId String
  url         String
  alt         String?
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  apartment   Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)

  @@index([apartmentId, sortOrder])
}

model Customer {
  id        String    @id @default(cuid())
  firstName String
  lastName  String
  email     String    @unique
  phone     String?
  street    String?
  houseNumber String?
  postalCode String?
  city      String?
  country   String?
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  bookings  Booking[]
}

model Booking {
  id              String        @id @default(cuid())
  apartmentId     String
  customerId      String
  checkIn         DateTime
  checkOut        DateTime
  guests          Int
  extraGuests     Int           @default(0)
  hasPet          Boolean       @default(false)
  laundryPackages Int           @default(0)
  status          BookingStatus @default(PENDING)
  totalPriceCents Int?
  currency        String        @default("EUR")
  newsletterOptIn Boolean       @default(false)
  notes           String?
  internalNotes   String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  apartment       Apartment     @relation(fields: [apartmentId], references: [id], onDelete: Restrict)
  customer        Customer      @relation(fields: [customerId], references: [id], onDelete: Restrict)
  invoice         Invoice?

  @@index([apartmentId, checkIn, checkOut])
  @@index([customerId])
  @@index([status])
}

model BookingPricingConfig {
  id                        String   @id
  extraGuestPerNightCents   Int      @default(1500)
  petFeePerNightCents       Int      @default(1000)
  laundryPackageFeeCents    Int      @default(1000)
  touristTaxPerPersonPerNightCents Int @default(0)
  cleaningFeeCents          Int      @default(0)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}

model Invoice {
  id                 String   @id @default(cuid())
  bookingId          String   @unique
  invoiceNumber      String   @unique
  issueDate          DateTime
  depositDueDate     DateTime
  balanceDueDate     DateTime
  totalAmountCents   Int
  depositAmountCents Int
  balanceAmountCents Int
  depositPaidAt      DateTime?
  balancePaidAt      DateTime?
  reminderLevel      Int      @default(0)
  nextReminderDueAt  DateTime?
  lastReminderSentAt DateTime?
  currency           String   @default("EUR")
  documentHtml       String
  emailSentAt        DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  booking            Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([issueDate])
}

model Rate {
  id               String    @id @default(cuid())
  apartmentId      String
  name             String
  startDate        DateTime
  endDate          DateTime
  nightlyPriceCents Int
  minNights        Int       @default(1)
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  apartment        Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)

  @@index([apartmentId, startDate, endDate])
}

model BlockedDate {
  id          String    @id @default(cuid())
  apartmentId String
  startDate   DateTime
  endDate     DateTime
  reason      String?
  createdAt   DateTime  @default(now())
  apartment   Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)

  @@index([apartmentId, startDate, endDate])
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  passwordResetTokenHash String? @unique
  passwordResetExpiresAt DateTime?
  displayName  String
  role         UserRole @default(MANAGER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
